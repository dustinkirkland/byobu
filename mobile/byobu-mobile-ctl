#!/bin/bash
set -euo pipefail

PORT=7432
DIR="$(cd "$(dirname "$0")" && pwd)"
PIDFILE="/tmp/byobu-mobile.pid"

# Detect installed vs dev-tree.
# Installed: script is in /usr/bin/, daemon is in /usr/lib/byobu-mobile/.
# Dev tree:  script is alongside byobu_mobile.py in mobile/.
if [ -f "$DIR/byobu_mobile.py" ]; then
    DAEMON="$DIR/byobu_mobile.py"
    PYTHON="${DIR}/.venv/bin/python"
    [ ! -x "$PYTHON" ] && PYTHON="python3"
    _DEV_TREE=1
else
    DAEMON="/usr/lib/byobu-mobile/byobu_mobile.py"
    PYTHON="python3"
    _DEV_TREE=0
fi

CONFIG_DIR="$HOME/.config/byobu-mobile"
LOGFILE="$CONFIG_DIR/byobu-mobile.log"

_ensure_dir() {
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
    touch "$LOGFILE"
    chmod 600 "$LOGFILE"
}

pid() {
    lsof -ti:"$PORT" 2>/dev/null | head -1
}

_ts_host() {
    tailscale status --json 2>/dev/null \
        | python3 -c "
import sys, json
d = json.load(sys.stdin)
name = d.get('Self', {}).get('DNSName', '').rstrip('.')
print(name)
" 2>/dev/null || true
}

_ensure_ts_serve() {
    # Idempotent: already configured.
    if tailscale serve status 2>/dev/null | grep -q ":${PORT}"; then
        echo "✓ tailscale serve already configured for port $PORT"
        return 0
    fi
    echo "Enabling tailscale serve (HTTPS → localhost:$PORT)..."
    # First attempt without sudo (works if user is already a tailscale operator).
    if tailscale serve --bg "$PORT" 2>/dev/null; then
        echo "✓ tailscale serve configured"
        return 0
    fi
    # Likely not an operator yet — set it and retry.
    echo "  (requires operator permission — running: sudo tailscale set --operator=$USER)"
    if sudo tailscale set --operator="$USER"; then
        echo "✓ $USER is now a Tailscale operator"
        if tailscale serve --bg "$PORT"; then
            echo "✓ tailscale serve configured"
            return 0
        fi
    fi
    echo "" >&2
    echo "Error: could not configure tailscale serve." >&2
    echo "Try manually:" >&2
    echo "  sudo tailscale set --operator=\$USER" >&2
    echo "  tailscale serve --bg $PORT" >&2
    return 1
}

case "${1:-}" in
  setup)
    # One-time setup: create venv, install deps, enable tailscale serve.
    # Pass --quiet to suppress the "Next steps" section (used by byobu-mobile-enable).
    SETUP_QUIET=0
    [ "${2:-}" = "--quiet" ] && SETUP_QUIET=1
    echo "=== byobu-mobile setup ==="
    echo ""

    # 1. Python / tornado
    if [ "$_DEV_TREE" = "1" ]; then
        if [ -d "$DIR/.venv" ]; then
            echo "✓ Python venv already exists ($DIR/.venv)"
        else
            echo "Creating Python virtual environment..."
            if command -v uv &>/dev/null; then
                uv venv "$DIR/.venv"
                uv pip install --python "$DIR/.venv/bin/python" -r "$DIR/requirements.txt"
            elif command -v python3 &>/dev/null; then
                python3 -m venv "$DIR/.venv"
                "$DIR/.venv/bin/pip" install -r "$DIR/requirements.txt"
            else
                echo "Error: neither uv nor python3 found in PATH" >&2
                exit 1
            fi
            echo "✓ Python venv created and dependencies installed"
        fi
    else
        echo "✓ Running installed (system python3 + python3-tornado)"
    fi

    # 2. Tailscale check
    if ! command -v tailscale &>/dev/null; then
        echo ""
        echo "Error: tailscale not found in PATH." >&2
        echo "Install Tailscale from https://tailscale.com/download, connect to your tailnet," >&2
        echo "then re-run setup." >&2
        exit 1
    fi
    TS_HOST=$(_ts_host)
    if [ -z "$TS_HOST" ]; then
        echo ""
        echo "Error: Tailscale is installed but not connected (no hostname found)." >&2
        echo "Run 'tailscale up' to connect, then re-run setup." >&2
        exit 1
    fi
    echo "✓ Tailscale connected as $TS_HOST"

    # 3. Enable tailscale serve
    _ensure_ts_serve || exit 1

    if [ "$SETUP_QUIET" = "0" ]; then
        echo ""
        echo "Setup complete. Next steps:"
        echo ""
        echo "  1. Start the daemon:      $0 start"
        echo "  2. Generate pairing code: $(dirname "$0")/byobu-mobile-pair"
        echo "  3. Open on your phone:    https://$TS_HOST"
    fi
    ;;

  start|serve)
    # Default mode: HTTPS via tailscale serve.
    # tailscale serve provisions a Let's Encrypt cert and proxies
    # https://<tailnet-hostname> → http://localhost:PORT.
    if p=$(pid); then
        echo "byobu-mobile already running (pid $p)"
        exit 1
    fi
    if ! command -v tailscale &>/dev/null; then
        echo "Error: tailscale not found in PATH" >&2
        echo "Use 'start-direct' for plain HTTP over Tailscale IP." >&2
        exit 1
    fi
    TS_HOST=$(_ts_host)
    if [ -z "$TS_HOST" ]; then
        echo "Error: cannot determine Tailscale hostname (is tailscale up?)" >&2
        exit 1
    fi
    _ensure_ts_serve || exit 1
    _ensure_dir
    echo "Starting byobu-mobile (HTTPS mode)..."
    nohup "$PYTHON" "$DAEMON" --host 127.0.0.1 --port "$PORT" --https \
        >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 0.5
    if p=$(pid); then
        echo "byobu-mobile started (pid $p)"
        echo "Connect from phone: https://$TS_HOST"
    else
        echo "byobu-mobile failed to start — check $LOGFILE"
        exit 1
    fi
    ;;

  start-local)
    # Loopback-only mode for SSH tunnel access.
    # Daemon binds to 127.0.0.1 only — no network exposure whatsoever.
    # Access via: ssh -L 7432:localhost:7432 user@this-machine
    # then open http://localhost:7432 in the phone browser.
    if p=$(pid); then
        echo "byobu-mobile already running (pid $p)"
        exit 1
    fi
    _ensure_dir
    echo "Starting byobu-mobile (loopback only — SSH tunnel access)..."
    nohup "$PYTHON" "$DAEMON" --host 127.0.0.1 --port "$PORT" \
        >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 0.5
    if p=$(pid); then
        echo "byobu-mobile started (pid $p)"
        echo "Access via SSH tunnel: ssh -L ${PORT}:localhost:${PORT} user@\$(hostname -f)"
        echo "Then open: http://localhost:${PORT}"
    else
        echo "byobu-mobile failed to start — check $LOGFILE"
        exit 1
    fi
    ;;

  start-direct)
    # Plain HTTP bound directly to Tailscale IP.
    # WireGuard encrypts the transport, but no TLS cert — dev/debug only.
    if p=$(pid); then
        echo "byobu-mobile already running (pid $p)"
        exit 1
    fi
    _ensure_dir
    echo "Starting byobu-mobile (direct HTTP — dev/debug only)..."
    nohup "$PYTHON" "$DAEMON" --port "$PORT" \
        >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 0.5
    if p=$(pid); then
        echo "byobu-mobile started (pid $p) — check $LOGFILE for bound address"
    else
        echo "byobu-mobile failed to start — check $LOGFILE"
        exit 1
    fi
    ;;

  stop)
    # Stops the daemon only.
    # tailscale serve config persists across restarts — run 'tailscale serve reset'
    # to remove it if you no longer want HTTPS proxying.
    if p=$(pid); then
        if [ -f "$PIDFILE" ] && [ "$(cat "$PIDFILE")" != "$p" ]; then
            echo "Error: pid $p owns port $PORT but does not match $PIDFILE ($(cat "$PIDFILE"))" >&2
            echo "Refusing to kill. Remove $PIDFILE manually if byobu-mobile is truly stopped." >&2
            exit 1
        fi
        kill "$p"
        echo "byobu-mobile stopped (pid $p)"
        rm -f "$PIDFILE"
    else
        echo "byobu-mobile not running"
        rm -f "$PIDFILE"
    fi
    ;;

  restart)
    "$0" stop 2>/dev/null || true
    sleep 0.5
    "$0" start
    ;;

  status)
    if p=$(pid); then
        echo "byobu-mobile running (pid $p) — port $PORT"
        # Show HTTPS URL only if tailscale serve is actually proxying to this port
        if tailscale serve status 2>/dev/null | grep -q ":${PORT}"; then
            TS_HOST=$(_ts_host)
            [ -n "$TS_HOST" ] && echo "Connect: https://$TS_HOST"
        else
            echo "Connect: http://$(tailscale ip -4 2>/dev/null || echo localhost):$PORT  (direct HTTP)"
        fi
    else
        echo "byobu-mobile not running"
    fi
    ;;

  log)
    tail -f "$LOGFILE"
    ;;

  *)
    echo "Usage: $0 {setup|start|start-local|start-direct|stop|restart|status|log}"
    echo ""
    echo "  setup         One-time setup: python check, tailscale serve"
    echo "  start         Start daemon via tailscale serve (HTTPS — default)"
    echo "  start-local   Start daemon loopback-only for SSH tunnel access"
    echo "  start-direct  Start daemon direct to Tailscale IP (HTTP — dev only)"
    echo "  stop          Stop daemon (tailscale serve config persists)"
    echo "  restart       Restart daemon"
    echo "  status        Show running status and URL"
    echo "  log           Tail the log"
    echo ""
    echo "  To remove tailscale serve config: tailscale serve reset"
    exit 1
    ;;
esac
