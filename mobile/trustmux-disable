set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
CTL="$DIR/trustmux-ctl"

_remove_hook() {
    local dest="$1"
    [ -w "$dest" ] || return 0
    # Remove any line that invokes trustmux-ctl (regardless of full path).
    sed -i '/trustmux-ctl/d' "$dest"
}

_remove_hook "$HOME/.profile"
_remove_hook "$HOME/.bash_profile"
_remove_hook "$HOME/.bash_login"
_remove_hook "$HOME/.zprofile"

# Stop the daemon right now (non-fatal: may not be running).
"$CTL" stop 2>/dev/null || true

echo
echo "Trustmux daemon stopped. It will no longer start automatically at login."
echo
echo "Paired device tokens are preserved in ~/.config/trustmux/tokens.json."
echo
echo "To re-enable later, run:"
echo "  trustmux-enable"
echo
